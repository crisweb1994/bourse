# =============================================================================
# Bourse — minimal env. Designed to get you running in ~2 minutes.
#
# Fastest path (no GitHub OAuth, no signup):
#   1. cp .env.example .env
#   2. paste ONE AI key (Anthropic OR OpenAI-compatible) below
#   3. docker compose --profile app up -d --build
#   4. open http://localhost:3000
#
# For multi-user mode, web search, custom data sources, feature flags,
# planner / hybrid preview / Redis — see `.env.production.example`.
# =============================================================================

# ---- Database (compose default, no edit needed) -----------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/bourse?schema=public"

# ---- Auth -------------------------------------------------------------------
# Single-user / private mode: set to false and skip GitHub OAuth entirely.
# Multi-user public mode: set true and fill GITHUB_* in .env.production.example.
AUTH_REQUIRED="false"

# Used to sign session JWTs. Generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-random-secret"

# Encrypts AI Provider API keys stored in PostgreSQL. Generate independently
# with: openssl rand -base64 32. JWT_SECRET is a compatibility fallback only.
AI_CREDENTIALS_ENCRYPTION_KEY="change-me-to-an-independent-random-secret"

# ---- Frontend ---------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ---- Image / build identity -------------------------------------------------
# Pin production deployments to an immutable release, for example:
# BOURSE_IMAGE="ghcr.io/crisweb1994/bourse:0.1.0"
BOURSE_IMAGE=""
BOURSE_VERSION="0.0.1-dev"
BOURSE_GIT_SHA="local"
BOURSE_BUILD_DATE="local"

# ---- AI provider (pick ONE) -------------------------------------------------
# Option A — Anthropic (Claude)
AI_PROVIDER="claude"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ---- Earnings brief --------------------------------------------------------
# Public cards use the environment provider above, never a user's key.
EARNINGS_BRIEF_ENABLED="true"
EARNINGS_LLM_ENABLED="true"
EARNINGS_DAILY_BUDGET_USD="5"
# Hard deadline shared by extraction and its optional repair pass (1-600s).
EARNINGS_EXTRACTION_TIMEOUT_MS="180000"
EARNINGS_GENERATION_CONCURRENCY="4"
# Lazy generation works without active detection. Enable polling explicitly.
EARNINGS_DETECTION_ENABLED="false"
# 1-10 minutes. At 5min × batch 50, provision for roughly 100 unique
# watchlist symbols per 10min window before upstream and generation latency.
EARNINGS_DETECTION_INTERVAL_MS="300000"
EARNINGS_DETECTION_BATCH_SIZE="50"
EARNINGS_DETECTION_CONCURRENCY="5"
EARNINGS_CONSENSUS_ENABLED="false"
EARNINGS_CONSENSUS_INTERVAL_MS="21600000"
EARNINGS_CONSENSUS_CONCURRENCY="5"
EARNINGS_CONSENSUS_MAX_AGE_MS="2592000000"

# Option B — OpenAI / OpenAI-compatible (DeepSeek, Kimi, 智谱, 通义, 火山方舟…)
# Set AI_PROVIDER="openai" above and uncomment:
# OPENAI_API_KEY=""
# OPENAI_BASE_URL=""          # e.g. https://api.deepseek.com/v1
# OPENAI_MODEL="gpt-4o-mini"
