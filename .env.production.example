# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=bourse

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_random_64_chars

# 独立加密数据库中的 AI Provider API Key；生成：openssl rand -base64 32
# 未配置时兼容回退 JWT_SECRET，但生产环境应始终使用独立密钥。
AI_CREDENTIALS_ENCRYPTION_KEY=change_me_independent_random_32_bytes

# 跨子域名共享 cookie 的父域名（前端和 API 在不同子域时必填）
# 例：前端 stock.example.com、API api.stock.example.com → COOKIE_DOMAIN=.example.com
# 本地开发留空
COOKIE_DOMAIN=.yourdomain.com

# GitHub OAuth — 在 https://github.com/settings/developers 创建 OAuth App
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# callback URL 格式：https://api.yourdomain.com/api/auth/github/callback
GITHUB_CALLBACK_URL=https://api.yourdomain.com/api/auth/github/callback

# ── Frontend public URL (baked into Next.js bundle at build time) ─────────────
# 必须是浏览器能访问的公网地址（含协议，不带末尾斜杠）
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# 前端域名（CORS 白名单）
FRONTEND_URL=https://yourdomain.com

# ── AI Provider ───────────────────────────────────────────────────────────────
# 选填 claude 或 openai；只需填对应的 KEY
AI_PROVIDER=openai

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_UTILITY_MODEL=

OPENAI_API_KEY=
OPENAI_BASE_URL=        # 留空使用官方；填自定义网关地址
OPENAI_MODEL=
OPENAI_UTILITY_MODEL=
