generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String   @id @default(cuid())
  githubId               String   @unique
  email                  String?
  name                   String
  avatarUrl              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  aiProviderSettings  AiProviderSetting[]
  watchlistItems      WatchlistItem[]
  analyses            Analysis[]
  webSearchSetting    WebSearchSetting?
  digestSubscription  DigestSubscription?
  deliveryRecords     DeliveryRecord[]
}

model Stock {
  id          String   @id @default(cuid())
  symbol      String
  name        String
  market      Market
  exchange    String
  currency    String   @default("USD")
  yahooSymbol String?
  // plan-v2 §11.1: sector filled by connector on first ingest (US: yahoo.sector
  // / CN: eastmoney BOARD_NAME / HK: yahoo.sector). Used by compute/relative.ts
  // for peer-group lookups.
  sector      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  watchlistItems WatchlistItem[]
  analyses       Analysis[]

  @@unique([symbol, market])
  @@index([sector])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  stockId   String
  notes     String?
  // plan-v2 §13.1.1: workspace Watchlist widget renders by order asc; user
  // drag-sort persists here. Default 0 puts new items at the top.
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
  @@index([userId, order])
}

model AiProviderSetting {
  id     String @id @default(cuid())
  userId String

  // multi-config fields (Phase 1)
  label             String? // 用户起的名字，e.g. "我的 DeepSeek"
  providerType      AiProviderType? // ANTHROPIC | OPENAI_COMPATIBLE
  enabledModels     String[]        @default([])
  isDefault         Boolean         @default(false)

  baseUrl         String?
  apiKey          String? // 明文存储（用户可在 Settings 页查看/编辑）
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Legacy model fallback for old rows created before primaryModel existed.
  model          String?
  /**
   * 主模型 (Primary). 主分析流式 / 主报告生成 / web_search 工具调用 /
   * 证据归一化。留空 → fallback 到 enabledModels[0] → legacy model。
   * UI 上必填; 后端校验须 ∈ enabledModels。
   */
  primaryModel   String?
  /**
   * 次模型 (Utility). 用于不需要强推理的辅助任务: structured JSON
   * 抽取/修复、COMPREHENSIVE summary、搜索查询改写。留空 → fallback
   * 到主 `model`。典型用法: model='gpt-5.5' + utilityModel='gpt-5.5-mini'。
   * 注意: web_search 工具调用 + 证据归一化仍走主 model 以保证引用准确性。
   */
  utilityModel   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum AiProviderType {
  ANTHROPIC
  OPENAI_COMPATIBLE
}

// plan-v2 §17.4.4 (2026-05-27) — WebSearchSetting reinstated. RFC:
// docs/web-search-per-user.md. Wave 4.5 had removed the table in favor
// of env-only config; reverted because users need to bring their own
// Tavily/SearXNG keys without re-deploying.
enum WebSearchProviderType {
  TAVILY
  SEARXNG
  // future: SERPER, BRAVE, GOOGLE_PSE
}

enum WebSearchPrimaryMode {
  NATIVE_FIRST // 优先用 provider 自带（Anthropic SDK / OpenAI Responses）
  CUSTOM_ONLY  // 强制走 user adapter（Anthropic 在 UI 隐藏；OpenAI 切到 chat.completions）
}

model WebSearchSetting {
  id              String                @id @default(cuid())
  userId          String                @unique
  providerType    WebSearchProviderType
  apiKey          String?
  baseUrl         String?               // SearXNG only
  primaryMode     WebSearchPrimaryMode  @default(NATIVE_FIRST)
  timeoutMs       Int?
  budgetUsdPerRun Decimal?              @db.Decimal(10, 4)
  cacheTtlMs      Int?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Daily Brief (docs/prd-daily-brief.md v1.5) — 定时行情简报订阅 + IM/Webhook
// 投递记录。完整简报只在 IM，不落库（BriefPayload 是运行时内存结构）。
model DigestSubscription {
  id         String   @id @default(cuid())
  userId     String   @unique
  markets    Market[]              // ["US","CN","HK"] 子集
  sessions   DigestSession[]      // ["PRE","POST"] 子集
  channels   Json                  // ChannelConfig[]（discriminated union，含凭证）
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeliveryRecord {
  id          String   @id @default(cuid())
  userId      String
  market      Market
  session     DigestSession
  channelType ChannelType
  target      String                  // 脱敏：url 域名 / chatId 末四位
  status      DeliveryStatus
  httpStatus  Int?
  error       String?
  attemptedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, attemptedAt])
  @@index([market, session, attemptedAt])
}

model Analysis {
  id                  String         @id @default(cuid())
  userId              String
  stockId             String
  symbol              String
  market              Market
  analysisType        AnalysisType
  status              AnalysisStatus @default(PENDING)
  aiProvider          String?
  aiModel             String?
  aiProviderSettingId String?
  dataAsOf            String?
  generatedAt         DateTime?
  summaryMarkdown     String?
  summaryJson         Json?
  overallSignal       Signal?
  overallConfidence   Confidence?
  // RFC rfc-evidence-pack-web-search-fallback: null = normal run; set to
  // 'WEB_SEARCH_FALLBACK' when EvidencePack came from the v1 web_search
  // builder after v2 hard-failed. Indexed for history filtering.
  degradedSource      String?

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock    Stock             @relation(fields: [stockId], references: [id], onDelete: Cascade)
  sections AnalysisSection[]

  @@index([userId, degradedSource])
}

model AnalysisSection {
  id             String         @id @default(cuid())
  analysisId     String
  type           SectionType
  status         AnalysisStatus @default(PENDING)
  reportMarkdown String?
  structuredJson Json?
  citations      Json?
  errorMessage   String?
  order          Int

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

// =============================================================================
// research-core persistence (PRD §12.2)
// Owned by apps/api as the only Prisma-aware layer. Implements
// research-core ResearchRepositoryPort.
// =============================================================================

enum Sensitivity {
  public
  restricted
  private
}

enum Market {
  US
  CN
  HK
}

enum DigestSession {
  PRE
  POST
}

enum DeliveryStatus {
  SENT
  FAILED
  RETRYING
}

enum ChannelType {
  WEBHOOK
  FEISHU
  DINGTALK
  WECOM
  TELEGRAM
  SLACK
}

enum AnalysisType {
  FUNDAMENTAL
  VALUATION
  INDUSTRY
  RISK
  TECHNICAL
  SENTIMENT
  SCENARIO
  PORTFOLIO
  GOVERNANCE
  COMPREHENSIVE
  DEBATE
}

enum SectionType {
  FUNDAMENTAL
  VALUATION
  INDUSTRY
  RISK
  TECHNICAL
  SENTIMENT
  SCENARIO
  PORTFOLIO
  GOVERNANCE
}

enum AnalysisStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  PARTIAL_FAILED
  FAILED
  CANCELLED
  BUDGET_EXHAUSTED
}

enum Signal {
  BULLISH
  NEUTRAL
  BEARISH
}

enum Confidence {
  HIGH
  MEDIUM
  LOW
}
