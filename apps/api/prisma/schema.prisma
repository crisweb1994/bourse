generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  githubId  String   @unique
  email     String?
  name      String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiProviderSettings     AiProviderSetting[]
  watchlistItems         WatchlistItem[]
  analyses               Analysis[]
  webSearchSetting       WebSearchSetting?
  digestSubscription     DigestSubscription?
  deliveryRecords        DeliveryRecord[]
  earningsDeliveryRecords EarningsDeliveryRecord[]
  researchThreads        ResearchThread[]
  earningsGenerationRuns EarningsGenerationRun[]
}

model Stock {
  id          String   @id @default(cuid())
  symbol      String
  name        String
  market      Market
  exchange    String
  currency    String   @default("USD")
  yahooSymbol String?
  // 由 connector 首次 ingest 写入，用于 compute/relative.ts 同行分组。
  sector      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  watchlistItems         WatchlistItem[]
  analyses               Analysis[]
  researchThreads        ResearchThread[]
  openResearchSnapshots  OpenResearchSnapshot[]
  filings                Filing[]
  earningsEvents         EarningsEvent[]
  earningsGenerationRuns EarningsGenerationRun[]
  earningsGuidance       EarningsGuidance[]
  earningsConsensusSnapshots EarningsConsensusSnapshot[]
  filingDetectionCursor  FilingDetectionCursor?
  earningsDeliveryRecords EarningsDeliveryRecord[]

  @@unique([symbol, market])
  @@index([sector])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  stockId   String
  notes     String?
  // 用户拖拽排序持久化；order asc 渲染；新增默认 0（置顶）。
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
  @@index([userId, order])
}

model AiProviderSetting {
  id     String @id @default(cuid())
  userId String

  label         String? // 用户起的名字，e.g. "我的 DeepSeek"
  providerType  AiProviderType? // ANTHROPIC | OPENAI_COMPATIBLE
  enabledModels String[]        @default([])
  isDefault     Boolean         @default(false)

  baseUrl         String?
  apiKey          String? // legacy plaintext; cleared after lazy migration
  apiKeyEncrypted String? // versioned AES-256-GCM ciphertext
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  /// 主模型：主分析 + web_search。留空 → fallback enabledModels[0]。
  primaryModel String?
  /// 次模型：JSON 抽取 / summary 等辅助任务。留空 → fallback 到 primaryModel。
  utilityModel String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum AiProviderType {
  ANTHROPIC
  OPENAI_COMPATIBLE
}

// 用户自配 Tavily/SearXNG key，避免依赖运维侧单一 env。
enum WebSearchProviderType {
  TAVILY
  SEARXNG
  // future: SERPER, BRAVE, GOOGLE_PSE
}

enum WebSearchPrimaryMode {
  NATIVE_FIRST // 优先用 provider 自带（Anthropic SDK / OpenAI Responses）
  CUSTOM_ONLY // 强制走 user adapter（Anthropic 在 UI 隐藏；OpenAI 切到 chat.completions）
}

model WebSearchSetting {
  id              String                @id @default(cuid())
  userId          String                @unique
  providerType    WebSearchProviderType
  apiKey          String?
  baseUrl         String? // SearXNG only
  primaryMode     WebSearchPrimaryMode  @default(NATIVE_FIRST)
  timeoutMs       Int?
  budgetUsdPerRun Decimal?              @db.Decimal(10, 4)
  cacheTtlMs      Int?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 定时行情简报订阅 + IM/Webhook 投递记录。完整简报只在 IM，不落库。
model DigestSubscription {
  id        String          @id @default(cuid())
  userId    String          @unique
  markets   Market[] // ["US","CN","HK"] 子集
  sessions  DigestSession[] // ["PRE","POST"] 子集
  channels  Json // ChannelConfig[]（discriminated union，含凭证）
  enabled   Boolean         @default(true)
  earningsImmediateEnabled Boolean @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeliveryRecord {
  id          String         @id @default(cuid())
  userId      String
  market      Market
  session     DigestSession
  channelType ChannelType
  target      String // 脱敏：url 域名 / chatId 末四位
  status      DeliveryStatus
  httpStatus  Int?
  error       String?
  attemptedAt DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, attemptedAt])
  @@index([market, session, attemptedAt])
}

model EarningsDeliveryRecord {
  id                 String               @id @default(cuid())
  dedupeKey          String               @unique
  userId             String
  stockId            String
  revisionId         String
  previousRevisionId String?
  kind               EarningsDeliveryKind
  channelType        ChannelType
  target             String
  status             DeliveryStatus
  httpStatus         Int?
  error              String?
  attemptedAt        DateTime             @default(now())
  deliveredAt        DateTime?

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock    Stock                 @relation(fields: [stockId], references: [id], onDelete: Cascade)
  revision EarningsCardRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@index([userId, stockId, attemptedAt])
  @@index([revisionId, status])
}

model Analysis {
  id                  String         @id @default(cuid())
  userId              String
  stockId             String
  symbol              String
  market              Market
  analysisType        AnalysisType
  question            String?
  status              AnalysisStatus @default(PENDING)
  aiProvider          String?
  aiModel             String?
  aiProviderSettingId String?
  promptVersion       String?
  dataAsOf            String?
  generatedAt         DateTime?
  summaryMarkdown     String?
  summaryJson         Json?
  overallSignal       Signal?
  overallConfidence   Confidence?
  // null = 正常运行；'WEB_SEARCH_FALLBACK' = EvidencePack v2 失败后降级到 v1 web_search。
  degradedSource      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock            Stock                     @relation(fields: [stockId], references: [id], onDelete: Cascade)
  sections         AnalysisSection[]
  evidenceSnapshot AnalysisEvidenceSnapshot?

  @@index([userId, degradedSource])
}

model AnalysisSection {
  id             String         @id @default(cuid())
  analysisId     String
  type           SectionType
  status         AnalysisStatus @default(PENDING)
  reportMarkdown String?
  structuredJson Json?
  citations      Json?
  errorMessage   String?
  order          Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

// Chat Phase 1 owns conversation records. AnalysisEvidenceSnapshot is written
// by the Analysis lifecycle and exposed to Chat through a read-only port.
enum ChatIntent {
  OPEN_RESEARCH
  EARNINGS_BRIEF
  EXPLAIN_EXISTING
  COMPARE_HISTORY
  REFRESH_REQUIRED
  VALIDATE_THESIS
  SCOPE_CHANGE
  UNSUPPORTED
}

enum ChatGenerationStatus {
  PENDING
  RUNNING
  COMPLETED
  CANCELLED
  FAILED
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM_NOTICE
}

enum ChatMessageKind {
  TEXT
  PROPOSAL
  DELTA_SUMMARY
  THESIS_REVIEW
  ERROR_NOTICE
}

enum ChatMessageStatus {
  COMPLETED
  PARTIAL
  FAILED
}

model ResearchThread {
  id             String    @id @default(cuid())
  userId         String
  primaryStockId String
  title          String
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryStock Stock            @relation(fields: [primaryStockId], references: [id], onDelete: Cascade)
  generations  ChatGeneration[]
  messages     ChatMessage[]

  @@index([userId, primaryStockId, updatedAt])
}

model ChatGeneration {
  id                        String               @id @default(cuid())
  threadId                  String
  clientRequestId           String
  intent                    ChatIntent
  status                    ChatGenerationStatus @default(PENDING)
  contextSnapshot           Json
  analysisContextSnapshotId String?
  earningsRevisionId       String?
  linkedAnalysisRunId       String?
  promptVersion             String
  actualProvider            String?
  actualModel               String?
  inputTokens               Int?
  outputTokens              Int?
  groundedSources           Json?
  errorCode                 String?
  createdAt                 DateTime             @default(now())
  completedAt               DateTime?

  thread                  ResearchThread               @relation(fields: [threadId], references: [id], onDelete: Cascade)
  messages                ChatMessage[]
  openResearchSnapshot    OpenResearchSnapshot?
  streamEvents            ChatStreamEvent[]
  analysisContextSnapshot ChatAnalysisContextSnapshot? @relation(fields: [analysisContextSnapshotId], references: [id], onDelete: SetNull)
  earningsRevision        EarningsCardRevision? @relation(fields: [earningsRevisionId], references: [id], onDelete: SetNull)

  @@unique([threadId, clientRequestId])
  @@index([threadId, status])
}

model ChatAnalysisContextSnapshot {
  id          String   @id @default(cuid())
  analysisId  String
  contentHash String   @unique
  payload     Json
  createdAt   DateTime @default(now())

  generations ChatGeneration[]

  @@index([analysisId, createdAt])
}

model ChatStreamEvent {
  id           String   @id @default(cuid())
  generationId String
  sequence     Int
  event        String
  payload      Json
  createdAt    DateTime @default(now())

  generation ChatGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@unique([generationId, sequence])
  @@index([generationId, sequence])
}

model ChatMessage {
  id           String            @id @default(cuid())
  threadId     String
  generationId String?
  role         ChatMessageRole
  kind         ChatMessageKind
  status       ChatMessageStatus
  content      String            @db.Text
  sequence     Int
  citationRefs Json?
  numericRefs  Json?
  createdAt    DateTime          @default(now())

  thread     ResearchThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  generation ChatGeneration? @relation(fields: [generationId], references: [id], onDelete: SetNull)

  @@unique([threadId, sequence])
  @@index([generationId])
}

model OpenResearchSnapshot {
  id                 String   @id @default(cuid())
  generationId       String   @unique
  stockId            String
  query              String   @db.Text
  dataAsOf           DateTime
  gatewayVersion     String
  sources            Json
  citationCandidates Json
  contentHash        String
  createdAt          DateTime @default(now())

  generation ChatGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  stock      Stock          @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId, createdAt])
}

model AnalysisEvidenceSnapshot {
  id                  String   @id @default(cuid())
  analysisId          String   @unique
  schemaVersion       String
  evidencePackVersion String
  capturedAt          DateTime @default(now())
  dataAsOf            Json
  sourceMode          String
  degraded            Boolean  @default(false)
  missingFields       String[]
  payload             Json
  sourceSnapshots     Json
  metadata            Json?
  contentHash         String

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

// Public filing artifacts and earnings cards. These rows are global facts,
// not user-owned analysis output. User references exist only for audit/scope.
model Filing {
  id               String             @id @default(cuid())
  stockId          String
  provider         String
  sourceDocumentId String
  sourceGroupId    String?
  formType         String
  documentKind     FilingDocumentKind
  title            String?
  sourceUrl        String
  publishedAt      DateTime
  retrievedAt      DateTime
  mimeType         String
  contentHash      String
  rawContent       Bytes
  createdAt        DateTime           @default(now())

  stock       Stock                 @relation(fields: [stockId], references: [id], onDelete: Cascade)
  derivations FilingDerivation[]
  eventLinks  EarningsEventFiling[]
  guidance    EarningsGuidance[]

  @@unique([provider, sourceDocumentId])
  @@index([stockId, publishedAt])
  @@index([contentHash])
}

model FilingDerivation {
  id             String                 @id @default(cuid())
  filingId       String
  derivationKey  String                 @unique
  parserVersion  String
  modelVersion   String
  promptVersion  String
  schemaVersion  String
  status         FilingDerivationStatus
  normalizedText String                 @db.Text
  contentHash    String
  pages          Json?
  sections       Json?
  extraction     Json?
  errorCode      String?
  errorMessage   String?
  createdAt      DateTime               @default(now())

  filing Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@index([filingId, createdAt])
}

// Forward-looking company guidance. It stays separate from actuals and is
// eligible only when issued before the actual filing publication time.
model EarningsGuidance {
  id                 String                  @id @default(cuid())
  dedupeKey          String                  @unique
  stockId            String
  filingId           String?
  metricCode         String
  targetPeriodEndOn  DateTime                @db.Date
  targetPeriodType   EarningsPeriodType
  valueMin           Decimal                 @db.Decimal(30, 8)
  valueMax           Decimal                 @db.Decimal(30, 8)
  unit               String
  currency           String?
  scale              Int                     @default(1)
  accountingBasis    String
  consolidationScope EarningsReportingScope
  issuedAt           DateTime
  provider           String
  sourceUrl           String
  sourceSpan          Json
  supersededAt        DateTime?
  createdAt           DateTime                @default(now())

  stock  Stock   @relation(fields: [stockId], references: [id], onDelete: Cascade)
  filing Filing? @relation(fields: [filingId], references: [id], onDelete: SetNull)

  @@index([stockId, targetPeriodEndOn, targetPeriodType, metricCode, issuedAt], map: "EarningsGuidance_lookup_idx")
  @@index([filingId])
}

// Only snapshots captured before publication can be attached to a card.
model EarningsConsensusSnapshot {
  id           String             @id @default(cuid())
  stockId      String
  metricCode   String
  periodEndOn  DateTime           @db.Date
  periodType   String
  value        Decimal            @db.Decimal(30, 8)
  unit         String
  currency     String?
  asOf         DateTime
  capturedAt   DateTime           @default(now())
  provider     String
  sourceUrl    String
  analystCount Int?
  expiresAt    DateTime?

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, metricCode, periodEndOn, periodType, provider, asOf], map: "EarningsConsensusSnapshot_identity_key")
  @@index([stockId, periodEndOn, periodType, metricCode, asOf], map: "EarningsConsensusSnapshot_lookup_idx")
}

model EarningsEvent {
  id             String                 @id @default(cuid())
  stockId        String
  periodEndOn    DateTime               @db.Date
  periodType     EarningsPeriodType
  reportingScope EarningsReportingScope
  fiscalYear     Int
  fiscalQuarter  Int?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  stock          Stock                   @relation(fields: [stockId], references: [id], onDelete: Cascade)
  filingLinks    EarningsEventFiling[]
  card           EarningsCard?
  generationRuns EarningsGenerationRun[]

  @@unique([stockId, periodEndOn, periodType, reportingScope])
  @@index([stockId, periodEndOn])
}

model EarningsEventFiling {
  eventId      String
  filingId     String
  relationType EarningsRelationType
  createdAt    DateTime             @default(now())

  event  EarningsEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  filing Filing        @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@id([eventId, filingId])
  @@index([filingId])
}

model EarningsCard {
  id                String   @id @default(cuid())
  eventId           String   @unique
  currentRevisionId String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  event           EarningsEvent          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  currentRevision EarningsCardRevision?  @relation("CurrentEarningsRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)
  revisions       EarningsCardRevision[] @relation("EarningsCardRevisions")
}

model EarningsCardRevision {
  id            String                     @id @default(cuid())
  cardId        String
  revisionNo    Int
  status        EarningsCardRevisionStatus
  schemaVersion String
  promptVersion String
  model         String?
  payload       Json
  contentHash   String
  inputTokens   Int                        @default(0)
  outputTokens  Int                        @default(0)
  costUsd       Decimal                    @default(0) @db.Decimal(12, 6)
  generatedAt   DateTime                   @default(now())
  supersededAt  DateTime?

  card           EarningsCard            @relation("EarningsCardRevisions", fields: [cardId], references: [id], onDelete: Cascade)
  currentFor     EarningsCard?           @relation("CurrentEarningsRevision")
  generationRuns EarningsGenerationRun[]
  chatGenerations ChatGeneration[]
  deliveryRecords EarningsDeliveryRecord[]

  @@unique([cardId, revisionNo])
  @@index([cardId, generatedAt])
}

model EarningsGenerationRun {
  id                String                   @id @default(cuid())
  stockId           String
  eventId           String?
  requestedByUserId String?
  cardRevisionId    String?
  clientRequestId   String?
  idempotencyKey    String                   @unique
  sourceDescriptor  Json
  status            EarningsGenerationStatus @default(QUEUED)
  stage             EarningsGenerationStage  @default(DISCOVER)
  attempt           Int                      @default(1)
  retryable         Boolean                  @default(true)
  errorCode         String?
  errorMessage      String?
  provider          String?
  model             String?
  inputTokens       Int                      @default(0)
  outputTokens      Int                      @default(0)
  costUsd           Decimal                  @default(0) @db.Decimal(12, 6)
  budgetReservedUsd Decimal                  @default(0) @db.Decimal(12, 6)
  createdAt         DateTime                 @default(now())
  startedAt         DateTime?
  completedAt       DateTime?

  stock        Stock                 @relation(fields: [stockId], references: [id], onDelete: Cascade)
  event        EarningsEvent?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  requestedBy  User?                 @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)
  cardRevision EarningsCardRevision? @relation(fields: [cardRevisionId], references: [id], onDelete: SetNull)

  @@unique([requestedByUserId, clientRequestId])
  @@index([stockId, createdAt])
  @@index([status, createdAt])
}

model FilingDetectionCursor {
  stockId              String   @id
  nextCheckAt          DateTime @default(now())
  leaseUntil           DateTime?
  lastCheckedAt        DateTime?
  lastDiscoveredAt     DateTime?
  lastSourceDocumentId String?
  failureCount         Int      @default(0)
  lastError            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([nextCheckAt, leaseUntil])
}

model EarningsSchedulerLease {
  key        String   @id
  ownerToken String?
  leaseUntil DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([leaseUntil])
}

enum FilingDocumentKind {
  PRIMARY
  EARNINGS_RELEASE
  PDF
  OTHER
}

enum FilingDerivationStatus {
  COMPLETE
  FAILED
}

enum EarningsPeriodType {
  Q1
  Q2
  Q3
  H1
  FY
}

enum EarningsReportingScope {
  CONSOLIDATED
  PARENT
  UNKNOWN
}

enum EarningsRelationType {
  SUPPLEMENTS
  CORRECTS
  SUPERSEDES
}

enum EarningsCardRevisionStatus {
  PARTIAL
  COMPLETE
}

enum EarningsGenerationStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  BUDGET_EXHAUSTED
}

enum EarningsGenerationStage {
  DISCOVER
  FETCH
  DERIVE
  EXTRACT
  CHECK
  RECONCILE
  INTERPRET
  PERSIST
  DONE
}

enum Market {
  US
  CN
  HK
}

enum DigestSession {
  PRE
  POST
}

enum DeliveryStatus {
  SENT
  FAILED
  RETRYING
}

enum ChannelType {
  WEBHOOK
  FEISHU
  DINGTALK
  WECOM
  TELEGRAM
  SLACK
}

enum EarningsDeliveryKind {
  NEW_CARD
  UPDATE
  CORRECTION
}

enum AnalysisType {
  FUNDAMENTAL
  VALUATION
  INDUSTRY
  RISK
  TECHNICAL
  SENTIMENT
  SCENARIO
  PORTFOLIO
  GOVERNANCE
  COMPREHENSIVE
  DEBATE // 已删除的功能，保留枚举值以兼容历史数据。
}

enum SectionType {
  FUNDAMENTAL
  VALUATION
  INDUSTRY
  RISK
  TECHNICAL
  SENTIMENT
  SCENARIO
  PORTFOLIO
  GOVERNANCE
}

enum AnalysisStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  PARTIAL_FAILED
  FAILED
  CANCELLED
  BUDGET_EXHAUSTED
}

enum Signal {
  BULLISH
  NEUTRAL
  BEARISH
}

enum Confidence {
  HIGH
  MEDIUM
  LOW
}
